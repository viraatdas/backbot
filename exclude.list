# Backbot exclusion list for duplicity
# Uses duplicity/rsync exclude pattern syntax

# Version control internals
**/.git

# Package managers & build artifacts
**/node_modules
**/__pycache__
**/build
**/dist
**/.next
**/.nuxt
**/target
**/.gradle
**/Pods
**/.eggs
**/*.egg-info

# macOS artifacts
**/.DS_Store
**/.Spotlight-V100
**/.fseventsd
**/.TemporaryItems

# macOS system caches and logs
Library/Caches
Library/Logs
Library/Developer
Library/Application Support/MobileSync
.Trash

# Package manager caches
.cache
.npm
.yarn/cache
.pnpm-store
.cargo/registry
.cargo/git
.rustup
.gradle/caches
.cocoapods
.gem
.cpan
.m2/repository

# Python virtual environments
**/.venv
**/venv
**/.tox
**/.mypy_cache
**/.pytest_cache

# Docker
.docker/buildx
Library/Containers/com.docker.*

# Steam and games
Library/Application Support/Steam/steamapps
Library/Application Support/Steam/SteamApps

# Large reproducible app data
Library/Application Support/Slack/Cache
Library/Application Support/Slack/Service Worker
Library/Application Support/discord/Cache
Library/Application Support/Google/Chrome/Default/Service Worker
Library/Application Support/Firefox/Profiles/*/cache2

# Virtual machines
**/*.vmdk
**/*.vdi
**/*.qcow2
**/VirtualBox VMs

# Temporary files
**/*.tmp
**/*.swp
**/*.swo
**/tmp

# Duplicity's own cache
.cache/duplicity

# Homebrew downloads
Library/Caches/Homebrew
